{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "staff", "user"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "totalSpent": { "type": "number" },
        "orderCount": { "type": "integer" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Product details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "compareAtPrice": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "subcategory": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] },
        "sku": { "type": "string" },
        "inventory": { "type": "integer" },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "inventory": { "type": "integer" },
              "sku": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "category", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "subtotal": { "type": "number" },
        "tax": { "type": "number" },
        "shipping": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid", "refunded", "partially_refunded"] },
        "shippingAddress": { "type": "object" },
        "trackingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "items", "total", "status", "createdAt"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount codes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["percentage", "fixed"] },
        "value": { "type": "number" },
        "minOrder": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "usageLimit": { "type": "integer" },
        "usageCount": { "type": "integer" },
        "active": { "type": "boolean" }
      },
      "required": ["id", "code", "type", "value", "active"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Store configuration",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "logo": { "type": "string" },
        "currency": { "type": "string" },
        "taxRate": { "type": "number" },
        "shippingZones": { "type": "array" },
        "contactEmail": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Discount codes"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Store configuration"
    }
  }
}
